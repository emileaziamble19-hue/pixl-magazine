---
layout: base.njk
title: "À la une"
---

{% set heroArticle = null %}
{% for art in collections.articles | reverse %}
  {% if art.data.hero and not heroArticle %}
    {% set heroArticle = art %}
  {% endif %}
{% endfor %}
{% if not heroArticle %}
  {% set heroArticle = collections.articles | reverse | first %}
{% endif %}

<!-- HERO -->
{% if heroArticle %}
<section class="hero">
  <div class="hero-lead">
    <div class="hero-pattern"></div>
    <div class="hero-lead-content fade-up">
      <div class="hero-kicker">
        <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="white"/></svg>
        {% if heroArticle.data.rubrique == "tech" %}Tech &amp; Numérique
        {% elif heroArticle.data.rubrique == "culture" %}Culture &amp; Arts
        {% elif heroArticle.data.rubrique == "mode" %}Mode africaine
        {% elif heroArticle.data.rubrique == "gastro" %}Gastronomie
        {% elif heroArticle.data.rubrique == "lit" %}Critique littéraire
        {% endif %}
      </div>
      <h1 class="hero-h1">{{ heroArticle.data.title }}</h1>
      <p class="hero-deck">{{ heroArticle.data.chapeau }}</p>
      <div class="hero-byline">Par {{ heroArticle.data.auteur }} &nbsp;&middot;&nbsp; {{ heroArticle.data.date | dateFormat }} &nbsp;&middot;&nbsp; {{ heroArticle.data.lecture }} de lecture</div>
      <a class="btn-read" href="{{ heroArticle.url }}">Lire l'article &rarr;</a>
    </div>
  </div>
  <div class="hero-stack">
    {% set stackCount = 0 %}
    {% for art in collections.articles | reverse %}
      {% if art.url != heroArticle.url and stackCount < 4 %}
        {% set stackCount = stackCount + 1 %}
        <a class="stack-item" href="{{ art.url }}">
          <div>
            <div class="stack-cat cat-{{ art.data.rubrique }}">
              {% if art.data.rubrique == "tech" %}Tech &amp; Numérique
              {% elif art.data.rubrique == "culture" %}Culture &amp; Arts
              {% elif art.data.rubrique == "mode" %}Mode africaine
              {% elif art.data.rubrique == "gastro" %}Gastronomie
              {% elif art.data.rubrique == "lit" %}Critique littéraire
              {% endif %}
            </div>
            <div class="stack-title">{{ art.data.title }}</div>
          </div>
          <div class="stack-meta">{{ art.data.auteur }} &middot; {{ art.data.date | dateFormat }}</div>
        </a>
      {% endif %}
    {% endfor %}
    {% if collections.articles | length <= 1 %}
      <div class="stack-item" style="justify-content:center;align-items:center;opacity:0.4;">
        <div class="stack-title" style="font-size:14px;text-align:center;">Tes prochains articles apparaîtront ici</div>
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

<!-- DERNIERS ARTICLES -->
<div class="sec-head">
  <span class="sec-name">Derniers articles</span>
  <div class="sec-line"></div>
</div>

{% if collections.articles | length > 0 %}
<section class="art-grid">
  {% set cardCount = 0 %}
  {% for art in collections.articles | reverse %}
    {% if cardCount < 3 %}
      {% set cardCount = cardCount + 1 %}
      <a class="art-card" href="{{ art.url }}">
        <div class="art-img">
          <div class="art-img-inner img-{{ art.data.rubrique }}-bg">
            {% if art.data.image %}
              <img src="{{ art.data.image }}" alt="{{ art.data.title }}" style="width:100%;height:100%;object-fit:cover;">
            {% else %}
              <span class="img-txt">{{ art.data.rubrique | upper }}</span>
            {% endif %}
          </div>
        </div>
        <div class="art-cat {{ art.data.rubrique }}">
          {% if art.data.rubrique == "tech" %}Tech &amp; Numérique
          {% elif art.data.rubrique == "culture" %}Culture &amp; Arts
          {% elif art.data.rubrique == "mode" %}Mode africaine
          {% elif art.data.rubrique == "gastro" %}Gastronomie
          {% elif art.data.rubrique == "lit" %}Critique littéraire
          {% endif %}
        </div>
        <h2 class="art-title">{{ art.data.title }}</h2>
        <p class="art-deck">{{ art.data.chapeau }}</p>
        <div class="art-meta">{{ art.data.auteur }} &middot; {{ art.data.lecture }}</div>
      </a>
    {% endif %}
  {% endfor %}
  <div class="sidebar">
    <div class="sidebar-sec">
      <div class="sidebar-sec-title">Tendances</div>
      {% set rankCount = 0 %}
      {% for art in collections.articles | reverse %}
        {% if rankCount < 4 %}
          {% set rankCount = rankCount + 1 %}
          <a class="rank-item" href="{{ art.url }}">
            <div class="rank-n">0{{ rankCount }}</div>
            <div>
              <div class="rank-title">{{ art.data.title }}</div>
              <div class="rank-meta" style="color:{% if art.data.rubrique == 'tech' %}var(--blue){% elif art.data.rubrique == 'culture' %}var(--purple){% elif art.data.rubrique == 'mode' %}var(--gold){% elif art.data.rubrique == 'gastro' %}var(--green){% else %}var(--red){% endif %}">
                {% if art.data.rubrique == "tech" %}Tech &amp; Numérique
                {% elif art.data.rubrique == "culture" %}Culture &amp; Arts
                {% elif art.data.rubrique == "mode" %}Mode africaine
                {% elif art.data.rubrique == "gastro" %}Gastronomie
                {% elif art.data.rubrique == "lit" %}Critique littéraire
                {% endif %}
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="about-box">
      <div class="about-logo">PIX<span class="r">L</span></div>
      <div class="about-tag">L'Afrique en haute définition</div>
      <div class="about-text">Magazine numérique indépendant fondé à Lomé, Togo. Tech, culture, mode, gastronomie et littérature couverts avec la précision et l'ambition que l'Afrique mérite.</div>
      <div class="about-origin">Fondé en {{ site.annee }} &middot; {{ site.ville }}</div>
    </div>
  </div>
</section>
{% else %}
<div class="empty-section">
  <p><strong>Le magazine est en ligne.</strong><br>Les articles publiés depuis le panneau d'administration apparaîtront ici.</p>
</div>
{% endif %}
