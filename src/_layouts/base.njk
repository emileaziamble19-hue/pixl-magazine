        <a href="{{ site.linkedin }}" title="LinkedIn">Li</a>
        <a href="{{ site.youtube }}" title="YouTube">Yt</a>
      </div>
    </div>
    <div class="ft-cols">
      <div class="ft-col">
        <h4>Rubriques</h4>
