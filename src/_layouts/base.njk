<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ site.description }}">
<title>{% if title %}{{ title }} — {% endif %}{{ site.titre }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=Outfit:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --ink:#0C0C0C;--paper:#F7F4EE;--red:#D42B1E;
  --gold:#C8952A;--blue:#0E2A6E;--purple:#6B2D8B;
  --green:#1A6B35;--smoke:#EDEAE3;--muted:#7A7670;
  --border:rgba(12,12,12,0.12);
}
html{scroll-behavior:smooth;}
body{background:var(--paper);color:var(--ink);font-family:'Outfit',sans-serif;font-weight:400;overflow-x:hidden;-webkit-font-smoothing:antialiased;}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
@keyframes ticker{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:0.3;}}
.fade-up{animation:fadeUp 0.6s ease both;}

/* TOP BAR */
.top-bar{background:var(--ink);color:var(--paper);display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:36px;font-size:11px;font-weight:500;letter-spacing:0.06em;}
.top-bar-left{display:flex;align-items:center;gap:20px;}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--red);display:inline-block;animation:pulse-dot 1.4s ease infinite;}
.top-bar-right{display:flex;gap:16px;}
.top-bar-right a{color:rgba(247,244,238,0.55);text-decoration:none;font-size:11px;transition:color 0.15s;}
.top-bar-right a:hover{color:var(--paper);}

/* HEADER */
header{background:var(--paper);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:200;}
.header-main{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 2rem;border-bottom:1px solid var(--border);min-height:72px;}
.header-left{display:flex;align-items:center;gap:16px;}
.logo-block{text-align:center;}
.logo-wordmark{font-family:'Bebas Neue',sans-serif;font-size:56px;letter-spacing:4px;line-height:1;color:var(--ink);display:block;text-decoration:none;}
.logo-wordmark .r{color:var(--red);}
.logo-tagline{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:12px;color:var(--muted);letter-spacing:0.12em;display:block;margin-top:-2px;}
.header-right{display:flex;align-items:center;justify-content:flex-end;gap:12px;}
.btn-sub{background:var(--ink);color:var(--paper);font-family:'Outfit',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:9px 18px;border:none;cursor:pointer;text-decoration:none;display:inline-block;transition:background 0.15s;}
.btn-sub:hover{background:var(--red);}
nav{display:flex;justify-content:center;overflow-x:auto;scrollbar-width:none;}
nav::-webkit-scrollbar{display:none;}
.nav-link{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;padding:12px 22px;color:var(--muted);border-bottom:2px solid transparent;white-space:nowrap;transition:color 0.15s,border-color 0.15s;text-decoration:none;display:inline-block;}
.nav-link:hover{color:var(--ink);}
.nav-link.active,.nav-link[data-active="true"]{color:var(--ink);border-bottom-color:var(--red);}

/* TICKER */
.ticker{background:var(--red);overflow:hidden;height:30px;display:flex;align-items:center;border-bottom:3px solid var(--ink);}
.ticker-label{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;color:var(--paper);background:var(--ink);padding:0 16px;height:100%;display:flex;align-items:center;flex-shrink:0;}
.ticker-scroll{overflow:hidden;flex:1;}
.ticker-inner{display:flex;animation:ticker 36s linear infinite;white-space:nowrap;}
.ticker-inner span{font-size:11px;font-weight:600;letter-spacing:0.08em;color:var(--paper);padding-right:60px;}
.ticker-sep{color:rgba(247,244,238,0.4)!important;}

/* HERO */
.hero{display:grid;grid-template-columns:1fr 340px;min-height:560px;border-bottom:3px solid var(--ink);}
.hero-lead{position:relative;overflow:hidden;border-right:1px solid var(--ink);background:var(--ink);display:flex;flex-direction:column;justify-content:flex-end;padding:2.5rem;min-height:560px;}
.hero-pattern{position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 28px,rgba(255,255,255,0.025) 28px,rgba(255,255,255,0.025) 29px),linear-gradient(160deg,#101820 0%,#1a0f0a 40%,#0a0e1a 100%);}
.hero-lead-content{position:relative;z-index:2;}
.hero-kicker{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:var(--paper);font-size:10px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;padding:4px 10px;margin-bottom:16px;}
.hero-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,52px);font-weight:700;line-height:1.08;color:var(--paper);margin-bottom:16px;max-width:620px;}
.hero-deck{font-size:15px;font-weight:300;line-height:1.7;color:rgba(247,244,238,0.72);max-width:520px;margin-bottom:22px;}
.hero-byline{font-size:12px;color:rgba(247,244,238,0.45);font-weight:500;letter-spacing:0.04em;margin-bottom:18px;}
.btn-read{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--paper);border:1px solid rgba(247,244,238,0.35);font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;padding:10px 20px;cursor:pointer;transition:background 0.2s,border-color 0.2s;text-decoration:none;}
.btn-read:hover{background:var(--red);border-color:var(--red);}
.hero-stack{display:flex;flex-direction:column;}
.stack-item{flex:1;padding:1.4rem 1.5rem;border-bottom:1px solid var(--border);transition:background 0.15s;display:flex;flex-direction:column;justify-content:space-between;text-decoration:none;color:inherit;}
.stack-item:last-child{border-bottom:none;}
.stack-item:hover{background:var(--smoke);}
.stack-cat{font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:7px;}
.cat-tech{color:var(--blue);}.cat-mode{color:var(--gold);}.cat-culture{color:var(--purple);}.cat-gastro{color:var(--green);}.cat-lit{color:var(--red);}
.stack-title{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:700;line-height:1.25;color:var(--ink);margin-bottom:8px;flex:1;}
.stack-meta{font-size:10px;color:var(--muted);font-weight:500;}

/* SECTION HEAD */
.sec-head{display:flex;align-items:center;gap:0;margin:0;border-bottom:1px solid var(--border);}
.sec-name{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--paper);background:var(--ink);padding:8px 20px;white-space:nowrap;}
.sec-line{flex:1;height:1px;background:var(--border);}
.sec-more{font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);padding:8px 20px;}

/* ARTICLE GRID */
.art-grid{display:grid;grid-template-columns:repeat(3,1fr) 280px;border-bottom:3px solid var(--ink);}
.art-card{padding:1.6rem;border-right:1px solid var(--border);transition:background 0.15s;text-decoration:none;color:inherit;display:flex;flex-direction:column;}
.art-card:hover{background:var(--smoke);}
.art-img{width:100%;height:130px;margin-bottom:14px;overflow:hidden;}
.art-img-inner{width:100%;height:100%;display:flex;align-items:center;justify-content:center;}
.img-tech-bg{background:linear-gradient(135deg,#081428,#0E2A6E);}
.img-culture-bg{background:linear-gradient(135deg,#1a0828,#6B2D8B);}
.img-mode-bg{background:linear-gradient(135deg,#281a04,#C8952A);}
.img-gastro-bg{background:linear-gradient(135deg,#041408,#1A6B35);}
.img-lit-bg{background:linear-gradient(135deg,#280404,#D42B1E);}
.img-txt{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;color:rgba(255,255,255,0.25);}
.art-cat{font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.art-cat::before{content:'';display:inline-block;width:18px;height:1.5px;}
.art-cat.tech{color:var(--blue);}.art-cat.tech::before{background:var(--blue);}
.art-cat.culture{color:var(--purple);}.art-cat.culture::before{background:var(--purple);}
.art-cat.mode{color:var(--gold);}.art-cat.mode::before{background:var(--gold);}
.art-cat.gastro{color:var(--green);}.art-cat.gastro::before{background:var(--green);}
.art-cat.lit{color:var(--red);}.art-cat.lit::before{background:var(--red);}
.art-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;line-height:1.25;margin-bottom:10px;color:var(--ink);}
.art-deck{font-size:13px;line-height:1.65;color:var(--muted);margin-bottom:12px;flex:1;}
.art-meta{font-size:10px;color:#aaa;font-weight:500;}

/* SIDEBAR */
.sidebar{border-left:1px solid var(--border);display:flex;flex-direction:column;}
.sidebar-sec{padding:1.4rem;border-bottom:1px solid var(--border);}
.sidebar-sec-title{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--muted);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.rank-item{display:flex;gap:10px;margin-bottom:14px;text-decoration:none;color:inherit;}
.rank-item:last-child{margin-bottom:0;}
.rank-n{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:700;color:var(--border);line-height:1;flex-shrink:0;width:26px;}
.rank-title{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;line-height:1.3;color:var(--ink);}
.rank-meta{font-size:10px;color:var(--muted);margin-top:3px;font-weight:500;}
.about-box{background:var(--ink);color:var(--paper);padding:1.4rem;flex:1;}
.about-logo{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px;margin-bottom:8px;}
.about-logo .r{color:var(--red);}
.about-tag{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:rgba(247,244,238,0.55);margin-bottom:12px;}
.about-text{font-size:12px;line-height:1.7;color:rgba(247,244,238,0.65);margin-bottom:12px;}
.about-origin{font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--red);}

/* DOUBLE SECTION */
.double-sec{display:grid;grid-template-columns:1fr 1fr;border-bottom:3px solid var(--ink);}
.half-sec{border-right:1px solid var(--ink);}
.half-sec:last-child{border-right:none;}
.half-grid{display:grid;grid-template-columns:1fr 1fr;}
.half-card{padding:1.4rem;border-right:1px solid var(--border);border-bottom:1px solid var(--border);transition:background 0.15s;text-decoration:none;color:inherit;display:flex;flex-direction:column;}
.half-card:nth-child(even){border-right:none;}
.half-card:nth-last-child(-n+2){border-bottom:none;}
.half-card:hover{background:var(--smoke);}
.badge{display:inline-block;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;padding:3px 8px;margin-bottom:10px;}
.badge-mode{background:var(--gold);color:#fff;}
.badge-gastro{background:var(--green);color:#fff;}
.badge-culture{background:var(--purple);color:#fff;}
.badge-lit{background:var(--red);color:#fff;}
.badge-tech{background:var(--blue);color:#fff;}
.half-title{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:700;line-height:1.25;color:var(--ink);margin-bottom:8px;}
.half-deck{font-size:12px;line-height:1.6;color:var(--muted);}

/* CULTURE STRIP */
.culture-strip{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:3px solid var(--ink);}
.cult-card{padding:1.6rem;border-right:1px solid var(--border);transition:background 0.15s;text-decoration:none;color:inherit;display:flex;flex-direction:column;}
.cult-card:last-child{border-right:none;}
.cult-card:hover{background:var(--smoke);}
.cult-num{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:700;color:var(--border);line-height:1;margin-bottom:8px;}
.cult-title{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:700;line-height:1.3;color:var(--ink);margin-bottom:8px;}
.cult-deck{font-size:12px;line-height:1.6;color:var(--muted);}

/* ARTICLE PAGE */
.article-wrap{max-width:800px;margin:0 auto;padding:3rem 2rem;}
.article-rubrique{font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
.article-rubrique::before{content:'';display:inline-block;width:22px;height:1.5px;}
.article-rubrique.tech{color:var(--blue);}.article-rubrique.tech::before{background:var(--blue);}
.article-rubrique.culture{color:var(--purple);}.article-rubrique.culture::before{background:var(--purple);}
.article-rubrique.mode{color:var(--gold);}.article-rubrique.mode::before{background:var(--gold);}
.article-rubrique.gastro{color:var(--green);}.article-rubrique.gastro::before{background:var(--green);}
.article-rubrique.lit{color:var(--red);}.article-rubrique.lit::before{background:var(--red);}
.article-titre{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,48px);font-weight:700;line-height:1.1;margin-bottom:20px;}
.article-chapeau{font-size:18px;font-weight:300;line-height:1.7;color:#444;border-left:3px solid var(--red);padding-left:20px;margin-bottom:24px;}
.article-meta{font-size:12px;color:var(--muted);font-weight:500;letter-spacing:0.06em;margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border);}
.article-cover{width:100%;height:280px;margin-bottom:3rem;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.article-cover img{width:100%;height:100%;object-fit:cover;}
.article-body{font-size:17px;line-height:1.9;color:#2c2c2c;font-weight:300;}
.article-body p{margin-bottom:1.6em;}
.article-body h2{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;margin:2.5em 0 1em;}
.article-body strong{font-weight:600;color:var(--ink);}
.article-body em{font-style:italic;}
.back-link{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;margin-bottom:2.5rem;transition:color 0.15s;}
.back-link:hover{color:var(--red);}

/* NEWSLETTER */
.nl-band{display:grid;grid-template-columns:1fr 1fr;background:var(--blue);border-bottom:3px solid var(--ink);}
.nl-left{padding:3rem 2.5rem;border-right:1px solid rgba(255,255,255,0.1);}
.nl-eyebrow{font-size:10px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:rgba(247,244,238,0.45);display:block;margin-bottom:12px;}
.nl-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3.5vw,40px);font-weight:700;color:var(--paper);line-height:1.1;margin-bottom:14px;}
.nl-title em{font-style:italic;color:var(--gold);}
.nl-sub{font-size:14px;font-weight:300;line-height:1.7;color:rgba(247,244,238,0.65);margin-bottom:16px;}
.nl-perks{display:flex;gap:12px;flex-wrap:wrap;}
.nl-perk{font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:rgba(247,244,238,0.5);padding:4px 10px;border:1px solid rgba(255,255,255,0.15);}
.nl-right{padding:3rem 2.5rem;display:flex;flex-direction:column;justify-content:center;}
.nl-form{display:flex;gap:0;margin-bottom:12px;}
.nl-input{flex:1;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);color:var(--paper);font-family:'Outfit',sans-serif;font-size:14px;padding:12px 16px;outline:none;}
.nl-input::placeholder{color:rgba(247,244,238,0.35);}
.nl-btn{background:var(--red);color:var(--paper);font-family:'Outfit',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:12px 20px;border:none;cursor:pointer;transition:background 0.15s;white-space:nowrap;}
.nl-btn:hover{background:#b51f14;}
.nl-note{font-size:11px;color:rgba(247,244,238,0.35);}

/* FOOTER */
footer{background:var(--ink);color:var(--paper);}
.ft-top{display:grid;grid-template-columns:280px 1fr;padding:3rem 2rem;gap:3rem;border-bottom:1px solid rgba(247,244,238,0.06);}
.ft-brand{display:flex;flex-direction:column;}
.ft-logo-big{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:4px;line-height:1;margin-bottom:8px;}
.ft-logo-big .r{color:var(--red);}
.ft-tagline-ft{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:rgba(247,244,238,0.4);margin-bottom:20px;}
.ft-social{display:flex;gap:10px;}
.ft-social a{width:34px;height:34px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(247,244,238,0.5);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;text-decoration:none;transition:all 0.15s;}
.ft-social a:hover{background:var(--red);border-color:var(--red);color:#fff;}
.ft-cols{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;}
.ft-col h4{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(247,244,238,0.3);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid rgba(247,244,238,0.06);}
.ft-col a{display:block;font-size:12px;color:rgba(247,244,238,0.45);text-decoration:none;margin-bottom:8px;transition:color 0.15s;}
.ft-col a:hover{color:var(--paper);}
.ft-bottom{padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;border-top:1px solid rgba(247,244,238,0.06);}
.ft-copy{font-size:11px;color:rgba(247,244,238,0.25);}
.ft-made{font-size:11px;font-weight:600;color:var(--red);}

/* EMPTY STATE */
.empty-section{padding:4rem 2rem;text-align:center;border-bottom:3px solid var(--ink);}
.empty-section p{font-size:15px;color:var(--muted);line-height:1.7;}
.empty-section strong{color:var(--ink);}

/* RESPONSIVE */
@media(max-width:1024px){
  .art-grid{grid-template-columns:1fr 1fr;}.sidebar{display:none;}
  .culture-strip{grid-template-columns:1fr 1fr;}
}
@media(max-width:768px){
  .hero{grid-template-columns:1fr;}
  .hero-stack{display:none;}
  .art-grid{grid-template-columns:1fr;}
  .double-sec{grid-template-columns:1fr;}
  .nl-band{grid-template-columns:1fr;}
  .ft-top{grid-template-columns:1fr;}
  .ft-cols{grid-template-columns:1fr 1fr;}
  .culture-strip{grid-template-columns:1fr 1fr;}
  .header-main{grid-template-columns:1fr auto 1fr;}
  .logo-wordmark{font-size:40px;}
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <div class="top-bar-left">
    <span><span class="live-dot"></span>&nbsp; En direct</span>
    <span id="date-live" style="color:rgba(247,244,238,0.45)"></span>
  </div>
  <div class="top-bar-right">
    <a href="/a-propos/">À propos</a>
    <a href="mailto:{{ site.email }}">Contact</a>
  </div>
</div>

<!-- HEADER -->
<header>
  <div class="header-main">
    <div class="header-left"></div>
    <div class="logo-block">
      <a href="/" class="logo-wordmark">PIX<span class="r">L</span></a>
      <span class="logo-tagline">— L'Afrique en haute définition</span>
    </div>
    <div class="header-right">
      <a href="#newsletter" class="btn-sub">S'abonner</a>
    </div>
  </div>
  <nav>
    <a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}">À la une</a>
    <a href="/rubrique/tech/" class="nav-link {% if rubrique == 'tech' %}active{% endif %}">Tech & Numérique</a>
    <a href="/rubrique/culture/" class="nav-link {% if rubrique == 'culture' %}active{% endif %}">Culture</a>
    <a href="/rubrique/mode/" class="nav-link {% if rubrique == 'mode' %}active{% endif %}">Mode</a>
    <a href="/rubrique/gastro/" class="nav-link {% if rubrique == 'gastro' %}active{% endif %}">Gastronomie</a>
    <a href="/rubrique/lit/" class="nav-link {% if rubrique == 'lit' %}active{% endif %}">Critiques</a>
  </nav>
</header>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-label">FLASH</div>
  <div class="ticker-scroll">
    <div class="ticker-inner" id="ticker-inner">
      {% for item in site.ticker %}
        <span>{{ item }}</span><span class="ticker-sep">·</span>
      {% endfor %}
      {% for item in site.ticker %}
        <span>{{ item }}</span><span class="ticker-sep">·</span>
      {% endfor %}
    </div>
  </div>
</div>

<!-- CONTENU PRINCIPAL -->
{{ content | safe }}

<!-- NEWSLETTER -->
<section class="nl-band" id="newsletter">
  <div class="nl-left">
    <span class="nl-eyebrow">Newsletter PIXL</span>
    <div class="nl-title">L'essentiel,<br><em>chaque semaine.</em></div>
    <div class="nl-sub">Tech, culture, mode, gastronomie et littérature — le meilleur de l'Afrique numérique livré dans votre boîte mail. Gratuit.</div>
    <div class="nl-perks">
      <span class="nl-perk">Sans spam</span>
      <span class="nl-perk">1 email / semaine</span>
      <span class="nl-perk">Désinscription facile</span>
    </div>
  </div>
  <div class="nl-right">
    <div class="nl-form">
      <input class="nl-input" type="email" placeholder="votre@email.com" id="nl-email">
      <button class="nl-btn" id="nl-submit">S'inscrire &rarr;</button>
    </div>
    <div class="nl-note" id="nl-note">Soyez parmi les premiers abonnés PIXL.</div>
  </div>
</section>

